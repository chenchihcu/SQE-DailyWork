# Project-local rules for trusted SQE DailyWork work.
# Data migrations, --apply operations, and cleanup deletes must prompt.

prefix_rule(
    pattern = [["pwsh", "powershell", "C:\\Program Files\\PowerShell\\7\\pwsh.exe", "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"], "-Command", "$env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python -m compileall main.py src scripts run_mig.py tests"],
    decision = "allow",
    justification = "SQE DailyWork compile verification is non-mutating and project-scoped.",
    match = [
        "pwsh -Command \"$env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python -m compileall main.py src scripts run_mig.py tests\"",
    ],
    not_match = [
        "pwsh -Command \"$env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\other-project\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python -m compileall main.py src scripts run_mig.py tests\"",
    ],
)

prefix_rule(
    pattern = [["pwsh", "powershell", "C:\\Program Files\\PowerShell\\7\\pwsh.exe", "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"], "-Command", "$env:PYTHONPATH='src;.'; $env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python -m unittest discover -s tests"],
    decision = "allow",
    justification = "SQE DailyWork unit test discovery is non-destructive and project-scoped.",
    match = [
        "pwsh -Command \"$env:PYTHONPATH='src;.'; $env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python -m unittest discover -s tests\"",
    ],
    not_match = [
        "pwsh -Command \"$env:PYTHONPATH='src;.'; $env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python scripts/recode_anomaly_no_all_dbs.py --apply\"",
    ],
)

prefix_rule(
    pattern = [["pwsh", "powershell", "C:\\Program Files\\PowerShell\\7\\pwsh.exe", "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"], "-Command", "$env:PYTHONPATH='src;.'; $env:QT_QPA_PLATFORM='offscreen'; $env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python -c \"from database.connection import initialize_database; from ui.main_window import MainWindow; from PySide6.QtWidgets import QApplication; initialize_database(); app=QApplication.instance() or QApplication([]); w=MainWindow(); print('tabs', w.stack.count()); w.close(); app.processEvents(); print('ui_smoke_ok')\""],
    decision = "allow",
    justification = "SQE DailyWork offscreen UI smoke is a bounded project verification command.",
    match = [
        "pwsh -Command \"$env:PYTHONPATH='src;.'; $env:QT_QPA_PLATFORM='offscreen'; $env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python -c \\\"from database.connection import initialize_database; from ui.main_window import MainWindow; from PySide6.QtWidgets import QApplication; initialize_database(); app=QApplication.instance() or QApplication([]); w=MainWindow(); print('tabs', w.stack.count()); w.close(); app.processEvents(); print('ui_smoke_ok')\\\"\"",
    ],
    not_match = [
        "pwsh -Command \"Remove-Item -LiteralPath backend -Recurse -Force\"",
    ],
)

prefix_rule(
    pattern = [["pwsh", "powershell", "C:\\Program Files\\PowerShell\\7\\pwsh.exe", "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"], "-Command", "$env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python run_mig.py"],
    decision = "prompt",
    justification = "SQE DailyWork migration commands can affect data and must be reviewed.",
    match = [
        "pwsh -Command \"$env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python run_mig.py\"",
    ],
    not_match = [
        "pwsh -Command \"$env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python -m compileall main.py src scripts run_mig.py tests\"",
    ],
)

prefix_rule(
    pattern = [["pwsh", "powershell", "C:\\Program Files\\PowerShell\\7\\pwsh.exe", "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"], "-Command", "$env:PYTHONPATH='src;.'; $env:UV_CACHE_DIR='C:\\Users\\user\\Documents\\SQE DailyWork\\.uv-cache'; uv run --no-project --with-requirements requirements.txt python scripts/recode_anomaly_no_all_dbs.py --apply"],
    decision = "prompt",
    justification = "SQE DailyWork recode --apply changes stored data and must be reviewed.",
