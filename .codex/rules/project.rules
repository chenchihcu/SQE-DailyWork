prefix_rule(
    pattern = [["pwsh", "powershell", "C:\\Program Files\\PowerShell\\7\\pwsh.exe", "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"], "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/harness_check.ps1"],
    decision = "allow",
    justification = "SQE DailyWork harness structure check is read-only and project-scoped.",
    match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/harness_check.ps1",
        "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/harness_check.ps1",
    ],
    not_match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/verify.ps1",
    ],
)

prefix_rule(
    pattern = [["pwsh", "powershell", "C:\\Program Files\\PowerShell\\7\\pwsh.exe", "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"], "-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", ".\\.venv\\Scripts\\python.exe scripts\\qt_visual_probe.py"],
    decision = "allow",
    justification = "SQE DailyWork native Qt visual probe is non-destructive and writes only a temp screenshot for visual evidence.",
    match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -Command \".\\.venv\\Scripts\\python.exe scripts\\qt_visual_probe.py\"",
        "pwsh -NoProfile -ExecutionPolicy Bypass -Command \".\\.venv\\Scripts\\python.exe scripts\\qt_visual_probe.py --target form-density\"",
        "powershell -NoProfile -ExecutionPolicy Bypass -Command \".\\.venv\\Scripts\\python.exe scripts\\qt_visual_probe.py\"",
        "powershell -NoProfile -ExecutionPolicy Bypass -Command \".\\.venv\\Scripts\\python.exe scripts\\qt_visual_probe.py --target form-density\"",
    ],
    not_match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -Command \".\\.venv\\Scripts\\python.exe scripts\\qt_visual_probe.py --allow-offscreen\"",
    ],
)

prefix_rule(
    pattern = [["pwsh", "powershell", "C:\\Program Files\\PowerShell\\7\\pwsh.exe", "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"], "-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "scripts/verify.ps1"],
    decision = "allow",
    justification = "SQE DailyWork full verification is non-destructive and project-scoped.",
    match = [
        "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/verify.ps1",
        "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify.ps1",
    ],
    not_match = [
